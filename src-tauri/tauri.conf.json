{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Koperasi",
  "version": "0.1.0",
  "identifier": "com.fikryfahrezy.koperasi",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Koperasi",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcwMEY4N0RGQ0NCQ0M0RTUKUldUbHhMek0zNGNQY0xtaFI2UGZQeU5PL1VpTXNxZWd4ZUJkRGtGZmU0LzZRaE9DVHBrRVFMUGUK",
      "endpoints": [
        "https://github.com/fikryfahrezy/tauri-template-w7/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "fixedRuntime",
        "path": "./Microsoft.WebView2.FixedVersionRuntime.88.0.705.81.x64/"
      }
    }
  }
}